# Copy this file to .env and fill in real values. .env is gitignored and
# must never be committed - this .env.example file is the only one that
# should ever be pushed to GitHub.
#
# All three services (users-service, books-service, rentals-service) load
# this SAME file from the repo root, since JWT_SECRET in particular must be
# identical across all three or cross-service authentication breaks.

# Shared HS256 signing key for the cross-service JWT. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
JWT_SECRET=

# Each service also needs its own Django SECRET_KEY (used for session/CSRF
# signing - it does NOT need to match across services). Generate one each
# with the same command above, or with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
USERS_SECRET_KEY=
BOOKS_SECRET_KEY=
RENTALS_SECRET_KEY=

# Database - set USE_SQLITE=0 to use MySQL (recommended), or leave at 1 to
# use SQLite with zero setup. DB_NAME differs per service (see the three
# per-service values below); DB_USER/DB_PASSWORD/DB_HOST/DB_PORT are shared.
USE_SQLITE=0
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
USERS_DB_NAME=users_db
BOOKS_DB_NAME=books_db
RENTALS_DB_NAME=rentals_db

# Celery / message broker. filesystem:// is a local dev stand-in (a shared
# directory acting as a queue, no broker server needed) - swap for a real
# amqp:// (RabbitMQ) or redis:// URL once you containerize.
CELERY_BROKER_URL=filesystem://
CELERY_FILESYSTEM_BROKER_DIR=
CELERY_TASK_ALWAYS_EAGER=0

# Where each service can be reached - used for cross-service links/redirects
# and rentals-service's one-time bootstrap sync. Defaults match the local
# dev ports used throughout the README.
USERS_SERVICE_PUBLIC_URL=http://localhost:8001
BOOKS_SERVICE_PUBLIC_URL=http://localhost:8002
RENTALS_SERVICE_PUBLIC_URL=http://localhost:8003
